{
  "expo": {
    "name": "Скидос",
    "slug": "dt64dnl55bin2kp4nhvjq",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "rork-app",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#071A10"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "store.skidos.store"
    },
    "android": {
      "package": "store.skidos.app",
      "googleServicesFile": "./google-services.json",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#071A10"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://app.skidos.store/"
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Скидос использует камеру, чтобы ты мог сфотографировать скидку и поделиться ей",
          "photosPermission": "Скидос использует фото, чтобы прикрепить картинку к скидке"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Скидос использует геолокацию, чтобы показать скидки рядом с тобой"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
